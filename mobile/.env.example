EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# On a physical device, use your machine's LAN IP:
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# Google sign-in
# Enable Google in Supabase Auth → Providers.
# Site URL must be https://YOUR_PROJECT.supabase.co (NOT skins://).
# Redirect URLs must include the exp://… URL shown on the onboarding screen in Expo Go,
# plus skins://auth/callback for production builds.

